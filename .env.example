# Oracle DB 연결 설정
ORACLE_URL=localhost:1521/XEPDB1
ORACLE_USER=planbridge
ORACLE_PASSWORD=your_password_here

# Git 저장소 기본 경로
REPOS_BASE_PATH=/repos

# Webhook 보안 시크릿 (GitHub webhook secret)
WEBHOOK_SECRET=your_webhook_secret_here

# 폴링 주기 (밀리초, 기본 5분)
POLL_INTERVAL_MS=300000

# 서버 포트
PORT=3001

# 로그 레벨 (error, warn, info, debug)
LOG_LEVEL=info

# 노드 환경
NODE_ENV=production
